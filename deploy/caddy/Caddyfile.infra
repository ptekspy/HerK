paddy.systems {
  encode zstd gzip

  handle_path /pgadmin* {
    reverse_proxy pgadmin:80 {
      header_up X-Script-Name /pgadmin
      header_up X-Forwarded-Prefix /pgadmin
      header_up X-Scheme {scheme}
    }
  }

  handle_path /redisinsight* {
    reverse_proxy redisinsight:5540
  }

  handle {
    respond "Infra proxy is running. Use /pgadmin or /redisinsight." 200
  }
}
