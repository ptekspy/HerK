# App runtime
NODE_ENV=production
DATABASE_URL=postgresql://contractguard:contractguard@contractguard-postgres:5432/contractguard?schema=contract_guard
REDIS_HOST=contractguard-redis
REDIS_PORT=6379
REDIS_PASSWORD=
CORS_ORIGINS=http://localhost,http://localhost:4000
PUBLIC_API_URL=http://localhost
FRONTEND_URL=http://localhost/app
AUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost
SESSION_COOKIE_NAME=cg_session
SESSION_TTL_DAYS=30
ALLOW_HEADER_AUTH=true

# GitHub App integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_APP_INSTALL_URL=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost/auth/github/callback

# Stripe (test mode recommended for local/staging)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost/app
STRIPE_CANCEL_URL=http://localhost/app
STRIPE_PORTAL_RETURN_URL=http://localhost/app

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=ContractGuard <alerts@example.com>

# Next public vars
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@contractguard.local
NEXT_PUBLIC_DEMO_USER_NAME=Demo User
NEXT_PUBLIC_GITHUB_OAUTH_URL=
NEXT_PUBLIC_WEB_URL=http://localhost
