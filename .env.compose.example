# App runtime
NODE_ENV=production
DATABASE_URL=postgresql://contractguard:contractguard@contractguard-postgres:5432/contractguard?schema=contract_guard
REDIS_HOST=contractguard-redis
REDIS_PORT=6379
REDIS_PASSWORD=
CORS_ORIGINS=https://apicontractguard.com,https://www.apicontractguard.com,https://paddy.systems,https://www.paddy.systems,http://localhost,http://localhost:4000
PUBLIC_API_URL=https://apicontractguard.com
FRONTEND_URL=https://apicontractguard.com/app
AUTH_ALLOWED_REDIRECT_ORIGINS=https://apicontractguard.com,https://www.apicontractguard.com,https://paddy.systems,https://www.paddy.systems,http://localhost,http://localhost:4000
SESSION_COOKIE_NAME=cg_session
SESSION_TTL_DAYS=30
ALLOW_HEADER_AUTH=true
INTERNAL_API_URL=http://contractguard-api:4001

# GitHub App integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_APP_INSTALL_URL=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://apicontractguard.com/auth/github/callback

# Stripe (test mode recommended for local/staging)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_STARTER_YEARLY=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_GROWTH_YEARLY=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_PRICE_ID_ENTERPRISE_YEARLY=
STRIPE_SUCCESS_URL=https://apicontractguard.com/app
STRIPE_CANCEL_URL=https://apicontractguard.com/app
STRIPE_PORTAL_RETURN_URL=https://apicontractguard.com/app

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=API Contract Guard <alerts@apicontractguard.com>

# Next public vars
NEXT_PUBLIC_API_URL=https://apicontractguard.com
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@apicontractguard.local
NEXT_PUBLIC_DEMO_USER_NAME=Demo User
NEXT_PUBLIC_GITHUB_OAUTH_URL=
NEXT_PUBLIC_WEB_URL=https://apicontractguard.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@apicontractguard.com
NEXT_PUBLIC_SALES_EMAIL=sales@apicontractguard.com
