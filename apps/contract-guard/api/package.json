    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.14",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/throttler": "^6.4.0",
    "@octokit/auth-app": "^8.1.1",
    "@octokit/rest": "^22.0.1",
    "bullmq": "^5.63.0",
