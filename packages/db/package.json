{
  "name": "@herk/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "main": "./dist/entry.js",
  "types": "./dist/entry.d.ts",
  "files": [
    "./dist/**",
    "./prisma/**"
  ],
  "scripts": {
    "build": "tsc -b -v",
    "dev": "pnpm prisma:generate && pnpm build --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "check-types": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2"
  },
  "devDependencies": {
    "@herk/eslint-config": "workspace:*",
    "@herk/typescript-config": "workspace:*",
    "@types/node": "^22.19.3",
    "prisma": "^6.16.2",
    "typescript": "5.9.3"
  }
}
